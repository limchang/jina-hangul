// ──────────────────────────────────────────────────────────
// [A] 새 스프레드시트 생성
// ──────────────────────────────────────────────────────────
function createMokpoRestaurantSheet() {
  var ss = SpreadsheetApp.create("목포 맛집 리뷰 키워드 분석 (56곳)");
  _buildSheet(ss);
  var url = ss.getUrl();
  Logger.log("생성 완료: " + url);
  SpreadsheetApp.getUi().alert("생성 완료!\n\n56곳 데이터 입력 완료.\n\n" + url);
}

